# =============================================================================
# .env.example — Python Backend — Shared Configuration
# Copy to .env.development for local dev.
# =============================================================================

# ---------- gRPC IPC (Go <-> Python) ----------
# Set GRPC_ENABLED=1 to start gRPC server alongside HTTP (port = HTTP port + 1000)
# Go connectors use gRPC-first, HTTP fallback when Python gRPC is available.
GRPC_ENABLED=0

# ---------- Internal Service URLs ----------
GO_GATEWAY_URL=http://127.0.0.1:9060
INDICATOR_SERVICE_URL=http://127.0.0.1:8092
GEOPOLITICAL_SOFT_SIGNAL_URL=http://127.0.0.1:8091
FINANCE_BRIDGE_URL=http://127.0.0.1:8081

# ---------- External API Keys (Optional for Python processing) ----------
# HuggingFace token for FinBERT inference if not running locally
FINBERT_HF_API_TOKEN=
FINBERT_HF_API_URL=https://api-inference.huggingface.co/models/ProsusAI/finbert
FINBERT_HF_TIMEOUT_MS=2500

# ---------- Cache & Persistence ----------
RUST_OHLCV_CACHE_ENABLED=true
RUST_OHLCV_CACHE_PATH=.cache/rust-ohlcv-cache.redb

# ---------- Logging & Debug ----------
LOG_LEVEL=INFO
DEBUG=true

# ---------- Phase 0e: Observability (OpenTelemetry + OpenObserve) ----------
# Set OTEL_ENABLED=true to activate OTLP gRPC trace export.
# Requires: opentelemetry-sdk, opentelemetry-instrumentation-fastapi,
#           opentelemetry-exporter-otlp-proto-grpc (installed via uv)
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317
