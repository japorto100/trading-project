# =============================================================================
# .env.example — Python Backend — Shared Configuration
# Copy to .env.development for local dev and fill in secrets.
# All services (python-agent, python-compute) load from this central file
# via services/_shared/app_factory.py (always resolves to python-backend/).
# =============================================================================

# ---------- Build & Dev Cache Paths (optional overrides) ----------
# By default uv, Cargo, Ruff and pytest use system cache dirs (~/AppData/... on Windows,
# ~/.cache/... on Linux/Mac). Override if your system drive is low on space.
# UV_CACHE_DIR=D:/cache/uv          # uv package + wheel cache
# CARGO_HOME=D:/cache/cargo         # Cargo registry + crate sources
# CARGO_TARGET_DIR=D:/cache/cargo-target   # Rust build artefacts (alternative to per-project target/)
# RUFF_CACHE_DIR=D:/cache/ruff      # ruff lint cache
# PYTEST_CACHE_DIR=D:/cache/pytest  # pytest result cache (also: cache_dir in pyproject.toml)

# ---------- gRPC IPC (Go <-> Python) ----------
# Set GRPC_ENABLED=1 to start gRPC server alongside HTTP (port = HTTP port + 1000)
# Go connectors use gRPC-first, HTTP fallback when Python gRPC is available.
GRPC_ENABLED=0
# GRPC_BACKEND=grpcio   # grpcio (default, Python 3.12) | grpclib (Python 3.13t/nogil)

# ---------- Internal Service URLs ----------
GO_GATEWAY_BASE_URL=http://127.0.0.1:9060
INDICATOR_SERVICE_URL=http://127.0.0.1:8092
GEOPOLITICAL_SOFT_SIGNAL_URL=http://127.0.0.1:8091
FINANCE_BRIDGE_URL=http://127.0.0.1:8081

# ---------- Agent / LLM (Phase 22d + 22f) ----------
AGENT_PROVIDER=anthropic
AGENT_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# OpenAI-compatible base URL (Ollama / vLLM / OpenRouter / Azure):
# OPENAI_BASE_URL=http://localhost:11434/v1

# Agent tool call timeout (seconds) — ABP.2d: prevents hanging tools from blocking the loop
AGENT_TOOL_TIMEOUT_SEC=30

# STT (Phase 22f ACR-A1): openai | whisper-local
AGENT_STT_PROVIDER=openai
# whisper-local: set OPENAI_BASE_URL above to point at WhisperLiveKit (Port 8095)

# TTS (Phase 22f ACR-A5): openai | kokoro
AGENT_TTS_PROVIDER=openai
AGENT_TTS_MODEL=tts-1
# Kokoro self-hosted (Port 8097, OpenAI-compatible):
# AGENT_TTS_BASE_URL=http://localhost:8097/v1

# ---------- External API Keys ----------
FINBERT_HF_API_TOKEN=
FINBERT_HF_API_URL=https://api-inference.huggingface.co/models/ProsusAI/finbert
FINBERT_HF_TIMEOUT_MS=2500
FINBERT_HF_CACHE_TTL_MS=600000
FINBERT_HF_CACHE_MAX_ENTRIES=2000

# ---------- Geopolitical Soft Signal POC Feature Flags ----------
# Set to true to enable experimental providers (default: false = disabled)
SOFT_SIGNAL_CHRONICLE_POC_ENABLED=false
SOFT_SIGNAL_SCOUT_POC_ENABLED=false
SOFT_SIGNAL_FINGPT_POC_ENABLED=false

# ---------- Cache & Persistence ----------
RUST_OHLCV_CACHE_ENABLED=true
RUST_OHLCV_CACHE_PATH=.cache/rust-ohlcv-cache.redb

# Cache provider: local (in-process LRU, default) | redis | valkey
# local  → no external dependency, LRU dict, no persistence
# redis  → tools/redis/redis-server.exe (Redis 5.0.14, Windows native, port 6379)
# valkey → Docker only (no Windows native binary), wire-compatible with redis client
MEMORY_CACHE_PROVIDER=local
# MEMORY_REDIS_ENABLED=false
# PYTHON_REDIS_URL — Python-backend dedicated Redis/Valkey (:6380 in dev).
#   Takes precedence over MEMORY_REDIS_URL / MEMORY_VALKEY_URL.
#   Go Gateway uses MEMORY_REDIS_URL (:6379) — separate instance.
# PYTHON_REDIS_URL=redis://127.0.0.1:6380/0
# MEMORY_REDIS_URL=redis://127.0.0.1:6380/0   (fallback when provider=redis)
# MEMORY_VALKEY_URL=redis://127.0.0.1:6380/0  (fallback when provider=valkey)

# ---------- Knowledge Graph (Memory Service) ----------
# KG provider: kuzu (default, file-based) | sqlite (fallback) | falkordb (Docker)
KG_PROVIDER=kuzu
KG_FORCE_SQLITE=false
KG_KUZU_PATH=
KG_SQLITE_PATH=
KG_FALKORDB_URL=redis://127.0.0.1:6381/0
KG_FALKORDB_GRAPH=tradeviewfusion

# ---------- Vector Store (Memory Service) ----------
# Provider: chroma (default, lightweight local) | lancedb (Arrow, hybrid search) | pgvector (Docker)
VECTOR_STORE_PROVIDER=chroma
VECTOR_STORE_PATH=
# Set to true in tests to skip model download (no sentence-transformers init)
VECTOR_STORE_MOCK=false
# LanceDB options (VECTOR_STORE_PROVIDER=lancedb)
VECTOR_STORE_LANCE_TABLE=memory
VECTOR_STORE_LANCE_HYBRID=false
# pgvector options (VECTOR_STORE_PROVIDER=pgvector, Docker)
VECTOR_STORE_PGVECTOR_DSN=postgresql://tradeview:tradeview-dev@127.0.0.1:5432/tradeviewfusion
VECTOR_STORE_PGVECTOR_TABLE=memory_embeddings

# ---------- Logging & Debug ----------
LOG_LEVEL=INFO
DEBUG=false

# ---------- Phase 0e: Observability (OpenTelemetry + OpenObserve) ----------
# Set OTEL_ENABLED=true to activate OTLP gRPC trace export.
# Requires OpenObserve running (dev-stack.ps1 -Observability or Docker).
# Dev (no Docker):  openobserve.exe on :5081 (gRPC) — started by dev-stack.ps1
# Prod (Docker):    otel-collector on :4317 → OpenObserve :5081
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317
# OPENOBSERVE_USER=root@example.com
# OPENOBSERVE_PASSWORD=
# OPENOBSERVE_ORG=default
